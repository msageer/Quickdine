{
  "version": 2,
  "builds": [
    { 
      "src": "server.ts", 
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["quickdine.db", "quickdine.db-shm", "quickdine.db-wal"]
      }
    },
    { "src": "package.json", "use": "@vercel/static-build" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.ts" },
    { "src": "/(.*)", "dest": "/dist/$1" },
    { "src": "/(.*)", "dest": "/dist/index.html" }
  ]
}
