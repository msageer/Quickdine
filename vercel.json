{
  "version": 2,
  "builds": [
    { 
      "src": "server.ts", 
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["quickdine.db", "quickdine.db-shm", "quickdine.db-wal"]
      }
    },
    { "src": "package.json", "use": "@vercel/static-build" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.ts" },
    { "source": "/uploads/(.*)", "destination": "/server.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
